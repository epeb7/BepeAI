# ============================================================
# BepeAI Backend — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o arquivo .env no repositório.
# ============================================================

# ── Servidor ─────────────────────────────────────────────────
PORT=3001
# Em produção SEMPRE use: NODE_ENV=production
NODE_ENV=development

# ── Segurança ─────────────────────────────────────────────────
# OBRIGATÓRIO — gere com: openssl rand -hex 32
# Em produção: mínimo 48 caracteres, sem palavras óbvias
JWT_SECRET=SUBSTITUA_POR_VALOR_GERADO_COM_OPENSSL
# Tempo de expiração do token (7d = 7 dias)
JWT_EXPIRES_IN=7d

# ── CORS — origens permitidas (separadas por vírgula) ─────────
# Em produção: use o domínio real (ex: https://app.bepeai.com)
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173

# ── IA (Groq) ────────────────────────────────────────────────
# Obtenha em: https://console.groq.com/keys
GROQ_API_KEY=gsk_SEU_GROQ_API_KEY_AQUI

# ── Autenticação ──────────────────────────────────────────────
ADMIN_EMAIL=admin@suaempresa.com

# PRODUÇÃO: use ADMIN_PASSWORD_HASH (nunca ADMIN_PASSWORD em produção)
# Gere o hash com: node -e "console.log(require('bcryptjs').hashSync('SuaSenhaForte!', 12))"
# A senha deve ter: mínimo 12 chars, letras, números e símbolos
ADMIN_PASSWORD_HASH=$2b$12$SEU_HASH_BCRYPT_AQUI

# DEV apenas (ignorado se ADMIN_PASSWORD_HASH estiver preenchido):
# ADMIN_PASSWORD=SUA_SENHA_AQUI

# ── Supabase ─────────────────────────────────────────────────
# Dashboard: https://supabase.com/dashboard
SUPABASE_URL=https://SEU_PROJETO.supabase.co

# service_role key (Project Settings > API > service_role)
# NUNCA exponha esta chave no frontend — poder total sobre o banco
SUPABASE_SERVICE_ROLE_KEY=eyJSEU_SERVICE_ROLE_KEY

# anon key — opcional, apenas leitura pública
SUPABASE_ANON_KEY=sb_publishable_SEU_ANON_KEY

# ── Logs ──────────────────────────────────────────────────────
# Produção: info | Dev: debug
LOG_LEVEL=debug
