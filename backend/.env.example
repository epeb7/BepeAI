# ============================================================
# BepeAI Backend — Variáveis de Ambiente
# Copie para .env e preencha os valores reais.
# NUNCA commite o .env no repositório.
# ============================================================

# ── Servidor ─────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Segurança ─────────────────────────────────────────────────
# Gere com: openssl rand -hex 32
JWT_SECRET=SUBSTITUA_POR_VALOR_GERADO_COM_OPENSSL
JWT_EXPIRES_IN=7d

# ── CORS — origens permitidas (separadas por vírgula) ─────────
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173

# ── IA ────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_SEU_GROQ_API_KEY_AQUI

# ── Autenticação (usuário único — fase dev) ───────────────────
ADMIN_EMAIL=admin@suaempresa.com
# Use ADMIN_PASSWORD_HASH (bcrypt, cost 12) em produção
# Gere com: node -e "console.log(require('bcryptjs').hashSync('SuaSenha', 12))"
ADMIN_PASSWORD_HASH=
# OU para dev apenas:
ADMIN_PASSWORD=SUA_SENHA_AQUI

# ── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=https://SEU_PROJETO.supabase.co
# service_role key: use no backend (nunca no frontend)
SUPABASE_SERVICE_ROLE_KEY=eyJSEU_SERVICE_ROLE_KEY
# anon key: apenas leitura pública (opcional, não usar para writes do backend)
SUPABASE_ANON_KEY=sb_publishable_SEU_ANON_KEY

# ── Logs ──────────────────────────────────────────────────────
LOG_LEVEL=debug
